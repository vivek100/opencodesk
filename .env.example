# ============================================================
# OpenCoDesk — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# --- OpenAI (required) ---
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Blaxel Cloud Sandbox (required) ---
# Sign up at: https://app.blaxel.ai
# Create a workspace and generate an API key.

BL_WORKSPACE=your-workspace
BL_API_KEY=your-api-key

# (optional) Sandbox image — defaults to blaxel/node:latest
BL_SANDBOX_TEMPLATE=blaxel/node:latest

# (optional) Blaxel region — defaults to us-was-1 in sandbox.ts if unset
BL_REGION=us-was-1

# --- Database (libSQL / Turso) ---
# Defaults to ./data/local.db when DATABASE_URL is unset.

# (optional) Turso for production
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-token

# --- Shared Drive & Filesystem Sandbox ---
# Created by `npm run setup` and written to .env.local automatically.
# Both the agent exec sandbox and the FS sandbox mount the same drive at /workspace.

# BL_DRIVE_ID=opencodesk-drive
# BL_FS_SANDBOX=opencodesk-fs

# (optional) Days before idle agent sandboxes are deleted — default 2
# SANDBOX_TTL_DAYS=2
